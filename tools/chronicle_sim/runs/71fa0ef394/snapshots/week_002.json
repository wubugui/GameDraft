      {
        "id": "evt_w1_river_dispute",
        "week_number": 1,
        "location_id": "loc_riverbank_west",
        "type_id": "river_dispute",
        "truth_json": "{\"what_happened\": \"上游赵家村为保秧苗私自筑坝截流，导致下游李家庄水车停摆。两村青壮在河岸对峙，赵家老者声称是'龙脉改道'，李家青年投石入水示警，未发生肢体冲突但局势紧张。\", \"who_knows_what\": {\"公开\": \"两村因缺水发生激烈口角，有人向河中投掷石块。\", \"仅当事人\": \"赵家村长私下承认截流是临时起意，并未请示乡绅；李家带头青年手中握有石子，原本瞄准的是赵家领头人的额头，但因犹豫未击中。\"}}",
        "director_draft_json": "{\"from_draft\": \"river_dispute: 上游村落截流灌溉，导致下游水位骤降，两村村民在河岸对峙...\"}",
        "witness_accounts_json": "[]",
        "rumor_versions_json": "[\"赵家请了邪术士截断了龙脉\", \"李家祖坟冒烟，惹怒了河神\"]",
        "tags_json": "[\"水源\", \"宗族冲突\", \"民生\"]",
        "supernatural_level": "none"
      },
      {
        "id": "evt_w1_debt_pressure",
        "week_number": 1,
        "location_id": "loc_market_entrance",
        "type_id": "debt_pressure",
        "truth_json": "{\"what_happened\": \"放贷人钱三在集市入口当众羞辱欠债书生柳文清，诵读借据并撕毁其一角衣袍。柳文清因家中老母病重无钱买药而违约，全程沉默忍受，围观者多为看客，无人援手。\", \"who_knows_what\": {\"公开\": \"书生柳文清欠债不还，被债主当街追讨，颜面扫地。\", \"仅当事人\": \"柳文清怀中藏有一枚当铺死当的玉佩，是他最后的救命稻草，但他不敢在众目睽睽下取出，怕被钱三抢走抵债。\"}}",
        "director_draft_json": "{\"from_draft\": \"debt_pressure: 债主在集市入口公开堵截一名落魄书生...\"}",
        "witness_accounts_json": "[]",
        "rumor_versions_json": "[]",
        "tags_json": "[\"债务\", \"市井\", \"羞辱\"]",
        "supernatural_level": "none"
      },
      {
        "id": "evt_w1_teahouse_gossip",
        "week_number": 1,
        "location_id": "loc_teahouse_central",
        "type_id": "teahouse_gossip",
        "truth_json": "{\"what_happened\": \"城南茶楼内，闲散人员议论昨日在乱葬岗附近发现的无名男尸。尸体衣着考究但面目全非，手中紧握半块玉佩。茶客们猜测死者与城中大户有关，但无人敢深究。\", \"who_knows_what\": {\"公开\": \"城里出了具无名尸，死状可疑，大家正在茶楼里瞎猜。\", \"仅当事人\": \"说书人老周其实认得那半块玉佩的纹样，那是城西王员外家失踪已久的二公子的贴身之物，但他选择装傻，只当趣闻讲。\"}}",
        "director_draft_json": "{\"from_draft\": \"teahouse_gossip: 茶客们压低声音议论近日城中出现的无名尸首...\"}",
        "witness_accounts_json": "[]",
        "rumor_versions_json": "[\"死者是被厉鬼索命\", \"王员外家清理门户\", \"江湖仇杀\"]",
        "tags_json": "[\"命案\", \"谣言\", \"豪门秘辛\"]",
        "supernatural_level": "rumor"
      },
      {
        "id": "evt_w2_teahouse_gossip",
        "week_number": 2,
        "location_id": "城南茶楼",
        "type_id": "teahouse_gossip",
        "truth_json": "{\"what_happened\": \"说书人老周为博眼球，刻意将无名尸案与城中权贵柳家联系起来。他并未掌握确凿证据，只是利用死者手中半块玉佩的纹饰模糊性，引导听众联想柳文清之死并非单纯债务纠纷，而是涉及更高层的政治或家族阴谋。\", \"who_knows_what\": {\"公开\": \"老周暗示玉佩纹饰似柳家徽记，茶客们开始怀疑柳文清得罪了惹不起的人。\", \"仅当事人\": \"老周其实并不确定玉佩归属，甚至没看清纹饰细节，全靠话术编排；柳家对此尚不知情，但谣言已起。\"}}",
        "director_draft_json": "{\"from_draft\": \"合并草案1：渲染舆论，将债务引向阴谋论\"}",
        "witness_accounts_json": "[]",
        "rumor_versions_json": "[\"柳家为了掩盖丑闻杀了柳文清\", \"那玉佩是某位大人物赐下的信物\"]",
        "tags_json": "[\"舆论\", \"柳家\", \"玉佩\", \"谣言\"]",
        "supernatural_level": "none"
      },
      {
        "id": "evt_w2_supernatural_omen",
        "week_number": 2,
        "location_id": "李家庄水车旁",
        "type_id": "supernatural_omen",
        "truth_json": "{\"what_happened\": \"上游截流导致李家庄段水位急剧下降，河床裸露。夜间风穿过干裂的河床缝隙与停摆的水车木质结构，产生类似婴儿啼哭的共振声。轮轴上的暗红色水草是因水位退去后暴露在空气中氧化变色，并因水流减缓而缠绕堆积，并非人为系结，但景象诡异。\", \"who_knows_what\": {\"公开\": \"村民听到哭声，看到血红水草，认为是河神发怒或冤魂索命。\", \"仅当事人\": \"无直接目击者见证'人为'痕迹，纯属自然现象与心理恐慌的结合。\"}}",
        "director_draft_json": "{\"from_draft\": \"合并草案2：断水引发的异象与恐慌\"}",
        "witness_accounts_json": "[]",
        "rumor_versions_json": "[\"河神因为断水在哭泣\", \"水草是淹死鬼的头发\", \"有人在水车底下做了诅咒仪式\"]",
        "tags_json": "[\"李家庄\", \"异象\", \"断水\", \"恐慌\"]",
        "supernatural_level": "ambiguous"
      }
