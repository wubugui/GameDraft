      "type": "line",
      "speaker": {
        "kind": "player"
      },
      "text": "上个月阎王岭那具邪尸，老子亲手背下山的！老搭尸的亲口教我的！",
      "next": "b3",
      "portrait": {
        "emotion": "calm"
      }
    },
    "b3": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "text": "真的假的……",
      "next": "end1",
