{
  "schemaVersion": 1,
  "id": "街巷_市井闲谈",
  "entry": "noodle_vendor",
  "meta": {
    "title": "街巷·市井闲谈"
  },
  "preconditions": [],
  "nodes": {
    "end": {
      "type": "end"
    },
    "noodle_vendor": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "面要趁烫吃，话要趁人多听。你站这儿一盏茶，半条街的闲账都能听明白。"
    },
    "washerwoman": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "莫踩水，刚洗好的衣裳晾不得脏气。城里这些天夜风怪，布上都有股庙灰味。"
    },
    "chess_grandpa": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "看棋不语真君子，看热闹不伸手才活得久。娃儿，你记到起。"
    },
    "sugar_child": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "我等老板转个龙出来。要是转到鸡，我就说它是凤凰。"
    },
    "chasing_child": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "让开让开！后头那个要抓我，我没偷他核桃，是核桃自己滚出来的！"
    },
    "coolie_rice_sack": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "一袋米压肩，三文钱压命。老板喊快点，路又不是他家修宽的。"
    },
    "coolie_rope": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "脚帮今天不接空话，只接现钱。要搬箱子，先把银角子摆出来。"
    },
    "lifu_runner": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "借过！码头那边催得凶，晚一步又要扣我脚钱。"
    },
    "paoge_teaman": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "街面上讲的是人情，背巷里讲的是规矩。你年纪轻，少问，少欠。"
    },
    "street_runner": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "我在前街跑腿送口信，谁家门槛都不进。雾津城路窄，人情比路还绕。"
    },
    "fortune_teller": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "算命不算死人账，问路不问夜半庙。你若偏要问，先添三文灯油钱。"
    },
    "ascetic_monk": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "一钵饭，半瓢水，贫僧够了。施主若心里有阴影，绕城隍庙走远些。"
    },
    "wandering_taoist": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "符纸好画，因果难贴。街上越热闹，越有人把亏心事藏在人声里。"
    },
    "constable_blade": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "让一让，巡街。闹事的去衙门说，不闹事的也别堵着路。"
    },
    "constable_resting": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "站岗也是活路，莫笑。你站一天试试，鞋底都能站出火星子。"
    },
    "foreign_lady": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "这条街吵得厉害，却什么都买得到。只是每个人看我的眼神，都像在估价。"
    },
    "foreign_cargo_hand": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "货箱要在街口验封，进了巷子再出事，谁都说不清。雾津的路，比账本难懂。"
    },
    "incense_granny": {
      "type": "line",
      "speaker": {
        "kind": "npc"
      },
      "next": "end",
      "text": "香烛纸钱都有，买不买随你。只是夜里经过庙门，手里有点亮光，总比空着好。"
    }
  }
}
