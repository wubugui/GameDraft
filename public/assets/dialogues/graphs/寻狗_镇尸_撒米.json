            "id": "sfx_rice_scatter"
          }
        }
      ],
      "next": "n_doing"
    },
    "n_doing": {
      "type": "line",
      "speaker": {
        "kind": "literal",
        "name": "旁白"
      },
      "text": "米粒砸在土地上，沙沙一圈。圈口合拢的那一下，像有什么撞了下无形的墙，顿了一顿。",
      "next": "n_sig"
    },
    "n_sig": {
