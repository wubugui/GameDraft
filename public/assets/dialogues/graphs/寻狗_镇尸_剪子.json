        "name": "旁白"
      },
      "text": "供桌上那把裁衣剪，黄铜柄都磨亮了。他张开剪口，横着搁在两尸正中间——",
      "next": "n_hold"
    },
    "n_hold": {
      "type": "runActions",
      "actions": [
        {
          "type": "startPressureHold",
          "params": {
            "id": "zhenshi_step"
          }
        },
        {
          "type": "playSfx",
          "params": {
            "id": "sfx_corpse_cloth_creak"
          }
        }
      ],
      "next": "n_doing"
    },
    "n_doing": {
      "type": "line",
      "speaker": {
        "kind": "literal",
        "name": "旁白"
      },
      "text": "剪子贴地的一瞬，庄里安静了一拍。连他自己的喘气声都听得见。",
      "next": "n_sig"
    },
    "n_sig": {
      "type": "runActions",
      "actions": [
        {
          "type": "emitNarrativeSignal",
          "params": {
