            "signal": "zhenshi_scissors_done"
          }
        }
      ],
      "next": "n_after"
    },
    "n_after": {
      "type": "line",
      "speaker": {
        "kind": "player"
      },
      "text": "（张口的剪，断的是纠缠。老辈人这么说的。……老辈人也没见过这阵仗吧。）",
      "next": "end1"
    },
