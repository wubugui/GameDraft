{
  "schemaVersion": 1,
  "id": "码头看板官差",
  "entry": "n_root",
  "meta": { "title": "码头看板官差" },
  "nodes": {
    "n_root": {
      "type": "switch",
      "cases": [
        {
          "conditions": [{ "flag": "码头_看板官差对话完结", "value": true }],
          "next": "n_sleep"
        }
      ],
      "defaultNext": "n_branch_notice"
    },
    "n_sleep": {
      "type": "line",
      "speaker": { "kind": "literal", "name": "旁白" },
      "text": "正在打瞌睡，不理你......",
      "next": "e1"
    },
    "e1": { "type": "end" },
    "n_branch_notice": {
      "type": "switch",
      "cases": [
        {
          "conditions": [{ "flag": "码头_已经和过码头告示交互过", "value": true }],
          "next": "n_abuse_1"
        }
      ],
      "defaultNext": "n_no_1"
    },
    "n_no_1": {
      "type": "line",
      "speaker": { "kind": "literal", "name": "旁白" },
      "text": "一个穿的破破烂烂的官差，正在打瞌睡......",
      "next": "n_no_2"
    },
    "n_no_2": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "莫去惹他。",
      "next": "e2"
    },
    "e2": { "type": "end" },
    "n_abuse_1": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "官爷......",
      "next": "n_abuse_2"
    },
    "n_abuse_2": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "zzz...",
      "next": "n_abuse_3"
    },
    "n_abuse_3": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "官爷！",
      "next": "n_abuse_4"
    },
    "n_abuse_4": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "干什么！死叫花！",
      "next": "n_abuse_5"
    },
    "n_abuse_5": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "嘿嘿。这告示上都写的啥啊？",
      "next": "n_abuse_6"
    },
    "n_abuse_6": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "不准下水！",
      "next": "n_abuse_7"
    },
    "n_abuse_7": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "为啥？",
      "next": "n_abuse_8"
    },
    "n_abuse_8": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "爬爬爬！个龟儿死叫花。",
      "next": "n_abuse_9"
    },
    "n_abuse_9": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "画那么大个水猴子看不见！",
      "next": "n_abuse_10"
    },
    "n_abuse_10": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "下水找死，要死你死远点。",
      "next": "n_main_choice"
    },
    "n_main_choice": {
      "type": "choice",
      "options": [
        { "id": "pay", "text": "掏摸几文，看能不能打点", "next": "n_pay_menu" },
        { "id": "leave", "text": "走开", "next": "n_walk_1" },
        {
          "id": "intel",
          "text": "搬几句听来的夜间忌讳诈他一诈",
          "next": "n_intel_1",
          "requireFlag": "rule_rule_no_go_night_acquired",
          "ruleHintId": "rule_no_go_night"
        }
      ]
    },
    "n_walk_1": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "懒得跟他歪缠。",
      "next": "e3"
    },
    "e3": { "type": "end" },
    "n_pay_menu": {
      "type": "choice",
      "options": [
        { "id": "c2", "text": "给两文", "next": "n_pay2_seq", "costCoins": 2 },
        { "id": "c6", "text": "给六文", "next": "n_pay6_1", "costCoins": 6 },
        { "id": "c12", "text": "给十二文", "next": "n_pay12_1", "costCoins": 12 },
        { "id": "cancel", "text": "算了", "next": "n_pay_cancel" }
      ]
    },
    "n_pay2_seq": {
      "type": "runActions",
      "actions": [{ "type": "removeCurrency", "params": { "amount": 2 } }],
      "next": "n_pay2_l1"
    },
    "n_pay2_l1": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "两文？你当老子是要饭的？",
      "next": "n_too_1"
    },
    "n_too_1": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "滚滚滚！别碍老子的眼！",
      "next": "n_too_2"
    },
    "n_too_2": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "……",
      "next": "e_too"
    },
    "e_too": { "type": "end" },
    "n_pay6_1": {
      "type": "runActions",
      "actions": [{ "type": "removeCurrency", "params": { "amount": 6 } }],
      "next": "n_pay6_l1"
    },
    "n_pay6_l1": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "行吧，算你识相。",
      "next": "n_pay6_l2"
    },
    "n_pay6_l2": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "那水下东西，码头上都叫水猴子，专找落单的下手。结伙过岸，别落单，比啥都强。",
      "next": "n_done_run"
    },
    "n_pay12_1": {
      "type": "runActions",
      "actions": [{ "type": "removeCurrency", "params": { "amount": 12 } }],
      "next": "n_pay12_l1"
    },
    "n_pay12_l1": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "哟，懂事。",
      "next": "n_pay12_l2"
    },
    "n_pay12_l2": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "告示底下还有行小字：水猴子爱拣落单的。人多绑在一块走，它不好下手——这话我只多告诉你一遍。",
      "next": "n_done_run"
    },
    "n_pay_cancel": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "老子才不当这冤大头。",
      "next": "e5"
    },
    "e5": { "type": "end" },
    "n_intel_1": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "官爷，我可是听说过的——夜里有些地方去不得，冲撞了比下水还麻烦。您在这码头上当差，总该懂这里头的分寸吧？",
      "next": "n_intel_2"
    },
    "n_intel_2": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "……哼。少跟老子扯这些有的没的。",
      "next": "n_intel_3"
    },
    "n_intel_3": {
      "type": "line",
      "speaker": { "kind": "npc" },
      "text": "你要真想知道，告示底下还有一行小字：水猴子专拣落单的拖下去。结伴过岸，互相看紧点，一般没事。",
      "next": "n_done_run"
    },
    "n_done_run": {
      "type": "runActions",
      "actions": [
        {
          "type": "showOverlayImage",
          "params": {
            "id": "水猴子告示",
            "image": "码头抓水猴子告示",
            "xPercent": 50,
            "yPercent": 50,
            "widthPercent": 40
          }
        },
        { "type": "waitClickContinue", "params": { "text": "" } },
        { "type": "hideOverlayImage", "params": { "id": "水猴子告示" } }
      ],
      "next": "n_done_line"
    },
    "n_done_line": {
      "type": "line",
      "speaker": { "kind": "player" },
      "text": "这片啥时候闹起了水猴子？头几天我还下水洗了澡......",
      "next": "n_done_flag"
    },
    "n_done_flag": {
      "type": "runActions",
      "actions": [
        { "type": "setFlag", "params": { "key": "码头_看板官差对话完结", "value": true } }
      ],
      "next": "e4"
    },
    "e4": { "type": "end" }
  }
}
