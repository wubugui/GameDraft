          "params": {
            "targetScene": "雾津街头",
            "targetSpawnPoint": "from_dream"
          }
        },
        {
          "type": "fadeWorldFromBlack",
          "params": {
            "durationMs": 1200
          }
        }
      ],
      "next": "end1"
    },
