    "done_1": {
      "type": "line",
      "speaker": {
        "kind": "literal",
        "name": "旁白"
      },
      "text": "这个画X的地方，已经过了。",
      "next": "end1"
    },
    "n1": {
      "type": "line",
      "speaker": {
        "kind": "literal",
        "name": "旁白"
      },
      "text": "第二个画X的地方。他离了队，下到林子边——黑黢黢的，一丝风都没得。",
      "next": "n2"
    },
    "n2": {
      "type": "line",
      "speaker": {
        "kind": "player"
      },
      "text": "（雇主教的那个名字……叫啥子来着？隔了一截路、一桩怪事，名字在脑壳里头打滑。）",
      "next": "c1",
      "portrait": {
        "emotion": "fear"
      }
    },
    "c1": {
      "type": "choice",
      "options": [
        {
          "id": "wrong_a",
          "text": "「陈世海——」",
          "next": "fb_wrong"
        },
        {
          "id": "right",
          "text": "「陈四海——」",
          "next": "fb_right"
        },
        {
          "id": "wrong_b",
          "text": "「陈四改——」",
          "next": "fb_wrong"
        },
        {
          "id": "skip",
          "text": "（这点瘆人得很……算了，不喊。回头说喊过了就是。）",
          "next": "fb_skip"
        }
      ]
    },
    "fb_right": {
      "type": "line",
      "speaker": {
        "kind": "literal",
        "name": "旁白"
      },
      "text": "回应来得慢了半拍。音，也不太对。他皱起眉，回头看了一眼。",
      "next": "sig_right"
    },
    "sig_right": {
      "type": "runActions",
      "actions": [
        {
          "type": "emitNarrativeSignal",
          "params": {
