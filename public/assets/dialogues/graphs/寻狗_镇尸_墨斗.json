          }
        },
        {
          "type": "playSfx",
          "params": {
            "id": "sfx_ink_line_snap"
          }
        }
      ],
      "next": "n_doing"
    },
    "n_doing": {
      "type": "line",
      "speaker": {
        "kind": "literal",
        "name": "旁白"
      },
      "text": "墨线弹在地上，一道笔直的黑。两具尸扭打的劲头，像被这道线从中间裁了一刀。",
      "next": "n_sig"
    },
    "n_sig": {
      "type": "runActions",
      "actions": [
