            "signal": "zhenshi_ink_done"
          }
        }
      ],
      "next": "n_after"
    },
    "n_after": {
      "type": "line",
      "speaker": {
        "kind": "player"
      },
      "text": "（木匠的线，裁的是木头。今儿裁的是什么，他不敢细想。）",
      "next": "end1"
    },
