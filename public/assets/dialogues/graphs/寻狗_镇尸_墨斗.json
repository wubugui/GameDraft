      "text": "墨斗线在指间绷直。他把线头钉在门槛，拉到供桌腿上，从两尸中间——绷！",
      "next": "n_hold"
    },
    "n_hold": {
      "type": "runActions",
      "actions": [
        {
          "type": "startPressureHold",
          "params": {
