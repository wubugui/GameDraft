      {
        "type": "playScriptedDialogue",
        "params": {
          "lines": [
            {
              "speaker": "",
              "text": "尸身落凳，肩头陡然一轻。贴了一路后颈的水腥气，总算散了。"
            },
            {
              "speaker": "{{player}}",
              "text": "交割了。找管事结钱切。"
            }
          ]
        }
      }
