  {
    "id": "peddler_arrives",
    "steps": [
      {
        "kind": "present",
        "type": "showDialogue",
        "speaker": "旁白",
        "text": "街巷口传来一阵吆喝声。"
      },
      {
        "kind": "present",
        "type": "cameraMove",
        "x": 200,
        "y": 700,
        "duration": 1000
      },
      {
        "kind": "present",
        "type": "showDialogue",
        "speaker": "货郎",
        "text": "桃木片嘞——糯米嘞——艾草嘞——驱邪避凶保平安嘞——"
      },
      {
        "kind": "present",
        "type": "showDialogue",
        "speaker": "旁白",
        "text": "一个挑着担子的汉子出现在街口。看他那担子上的东西，倒都是些驱邪辟邪的玩意儿。"
      },
      {
        "kind": "present",
        "type": "cameraMove",
        "x": 600,
        "y": 500,
        "duration": 800
      },
      {
        "kind": "present",
        "type": "waitClick"
      },
      {
        "kind": "present",
        "type": "showDialogue",
        "speaker": "旁白",
        "text": "也许该去看看他卖的是什么。"
      }
    ]
  },
