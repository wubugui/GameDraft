        "y": 300,
        "duration": 1500
      },
      {
        "type": "camera_zoom",
        "scale": 1.3,
        "duration": 1500,
        "parallel": true
      },
      {
        "type": "show_dialogue",
        "speaker": "系统",
        "text": "摄像机移动和缩放同时执行（parallel测试）。"
      },
      {
        "type": "flash_white",
        "duration": 200
      },
      {
        "type": "wait_click"
      },
      {
