      },
      {
        "type": "show_title",
        "text": "测试结束",
        "duration": 1500
      },
      {
        "type": "set_flag",
        "key": "test_cutscene_done",
        "value": true
      }
    ]
  },
  {
    "id": "mysterious_visitor",
    "commands": [
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "街巷尽头传来脚步声……"
      },
      {
        "type": "entity_spawn",
        "id": "cloaked_figure",
        "name": "???",
        "x": 1100,
        "y": 500
      },
      {
        "type": "entity_emote",
        "target": "player",
        "emote": "?",
        "duration": 1200
      },
      {
        "type": "entity_move",
        "target": "cloaked_figure",
        "x": 700,
        "y": 500,
        "speed": 80
      },
      {
        "type": "camera_move",
        "x": 850,
        "y": 500,
        "duration": 2000,
        "parallel": true
      },
      {
        "type": "entity_face",
        "target": "cloaked_figure",
        "faceTarget": "player"
      },
      {
        "type": "entity_face",
        "target": "player",
        "faceTarget": "cloaked_figure"
      },
      {
        "type": "entity_emote",
        "target": "cloaked_figure",
        "emote": "!",
        "duration": 1000
      },
      {
        "type": "show_dialogue",
        "speaker": "???",
        "text": "小子，你就是关二狗？"
      },
      {
        "type": "show_dialogue",
        "speaker": "关二狗",
        "text": "你谁啊？找我有事？"
      },
      {
        "type": "show_dialogue",
        "speaker": "???",
        "text": "有件事……算了，时候未到。"
      },
      {
        "type": "entity_move",
        "target": "cloaked_figure",
        "x": 1100,
        "y": 500,
        "speed": 120
      },
      {
        "type": "entity_move",
        "target": "player",
        "x": 500,
        "y": 500,
        "speed": 100,
        "parallel": true
      },
      {
        "type": "entity_emote",
        "target": "player",
        "emote": "...",
        "duration": 1500
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "那人转身快步离去，消失在巷子尽头。这是谁？他怎么知道你的名字？"
      },
      {
        "type": "entity_remove",
        "id": "cloaked_figure"
      },
      {
        "type": "set_flag",
        "key": "met_mysterious_visitor",
        "value": true
      },
      {
        "type": "camera_move",
        "x": 600,
        "y": 500,
        "duration": 500
      }
    ]
  },
  {
    "id": "temple_strangers_arrive",
    "commands": [
      {
        "type": "show_img",
        "id": "iron_box_closeup",
        "image": "/assets/images/illustrations/iron_box_closeup.png"
      },
      {
        "type": "play_sfx",
        "id": "iron_box_chime"
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "你把铁盒推进砖缝的一瞬，掌心像被冰水浸了一下。"
      },
      {
        "type": "hide_img",
        "id": "iron_box_closeup"
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "你刚把铁盒塞进城隍像后的砖缝里，庙门外忽然传来细碎的脚步声。"
      },
      {
        "type": "entity_spawn",
        "id": "temple_tall_man",
        "name": "高个汉子",
        "x": 520,
        "y": 930
      },
      {
        "type": "entity_spawn",
        "id": "temple_short_man",
        "name": "矮汉子",
        "x": 620,
        "y": 930
      },
      {
        "type": "entity_spawn",
        "id": "temple_woman",
        "name": "女人",
        "x": 570,
        "y": 940
      },
      {
        "type": "entity_move",
        "target": "temple_woman",
        "x": 580,
        "y": 720,
        "speed": 80
      },
      {
        "type": "entity_move",
        "target": "temple_tall_man",
        "x": 500,
        "y": 750,
        "speed": 90,
        "parallel": true
      },
      {
        "type": "entity_move",
        "target": "temple_short_man",
        "x": 660,
        "y": 750,
        "speed": 85,
        "parallel": true
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "你赶紧缩到柱子后头，只听见两个汉子压着嗓子和那女人争执，字句听不真切。"
      },
      {
        "type": "show_dialogue",
        "speaker": "女人",
        "text": "你们到底想做什么！"
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "下一瞬，一声短促的惨叫在空庙里炸开，听得你后背一麻。"
      },
      {
        "type": "entity_remove",
        "id": "temple_woman"
      },
      {
        "type": "entity_remove",
        "id": "temple_tall_man"
      },
      {
        "type": "entity_remove",
        "id": "temple_short_man"
      },
      {
        "type": "set_flag",
        "key": "strangers_entered_temple",
        "value": true
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "庙里很快又静了下来。你既想立刻逃走，又实在惦记砖缝里的铁盒还在不在。"
      },
      {
        "type": "camera_move",
        "x": 910,
        "y": 480,
        "duration": 1200
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "你屏住气，往庙门口挪了两步。月光从破屋顶漏下来，斜斜照在墙边……那边似乎有什么。"
      }
    ]
  },
  {
    "id": "day_2_dawn",
    "commands": [
      {
        "type": "fade_black",
        "duration": 800
      },
      {
        "type": "show_img",
        "id": "ghost_bride_memory",
        "image": "/assets/images/illustrations/ghost_bride_flashback.png"
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "你半梦半醒间，又梦见两个月前替人背阴婚新娘的那一夜。她压得你喘不过气，你和那张惨白的脸贴得太近，近得像要把魂也看出来。"
      },
      {
        "type": "hide_img",
        "id": "ghost_bride_memory"
      },
      {
        "type": "show_title",
        "text": "第二天",
        "duration": 2000
      },
      {
        "type": "fade_in",
        "duration": 1000
      }
    ]
  },
  {
    "id": "prologue_demo_end",
    "commands": [
      {
        "type": "fade_black",
        "duration": 800
      },
      {
        "type": "play_sfx",
        "id": "reveal_sting"
      },
      {
        "type": "show_img",
        "id": "corpse_reveal",
        "image": "/assets/images/illustrations/female_corpse_portrait.png"
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "梁上的那张脸，和你记忆里那具阴婚新娘的脸，像隔着两个月的晦气忽然重叠在了一起。"
      },
      {
        "type": "show_dialogue",
        "speaker": "关二狗",
        "text": "……怎么会是她？"
      },
      {
        "type": "hide_img",
        "id": "corpse_reveal"
      },
      {
        "type": "show_img",
        "id": "bridge_hint",
        "image": "/assets/images/backgrounds/bridge_underpass_bg.png"
      },
      {
        "type": "show_title",
        "text": "第七夜 · 桥下",
        "duration": 1800
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "瞎子李要你最后一晚带着盒子去水库桥下见他。可现在，盒子、城隍庙、那张脸，还有你没敢细想的旧事，已经全缠到了一起。"
      },
      {
        "type": "set_flag",
        "key": "prologue_demo_complete",
        "value": true
      },
      {
        "type": "show_title",
        "text": "序章 Demo 到此",
        "duration": 1600
      },
      {
        "type": "hide_img",
        "id": "bridge_hint"
      },
      {
        "type": "fade_in",
        "duration": 800
      }
    ]
  }
]
