[
  {
    "id": "prologue_opening",
    "commands": [
      {
        "type": "show_img",
        "id": "legend_story",
        "image": "/assets/images/illustrations/li_tiangou_story.png"
      },
      {
        "type": "play_sfx",
        "id": "story_intro"
      },
      {
        "type": "show_title",
        "text": "渝都卫",
        "duration": 1
      },
      {
        "type": "wait_time",
        "duration": 1
      },
      {
        "type": "show_title",
        "text": "第一天",
        "duration": 1
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "茶馆里，张叨叨正说到李天狗的段子。说那道士上神仙顶、斗魃烧尸，最后连赏钱都不收，拂袖就没了影。"
      },
      {
        "type": "hide_img",
        "id": "legend_story"
      },
      {
        "type": "set_flag",
        "key": "prologue_started",
        "value": true
      },
      {
        "type": "fade_in",
        "duration": 1
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "渝都卫，地处西南山区盆地。时值军阀割据，外面没个太平日子，城里也好不到哪里去。"
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "你——关二狗，从小没爹没娘，混迹于街头，靠帮人跑腿混口饭吃。今天你照例在城里转悠，想看看有什么营生可做。"
      }
    ]
  },
  {
    "id": "prologue_day_end",
    "commands": [
      {
        "type": "fade_black",
        "duration": 1000
      },
      {
        "type": "show_title",
        "text": "第一天结束",
        "duration": 2000
      },
      {
        "type": "set_flag",
        "key": "day_1_done",
        "value": true
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "天色渐暗，你回到了住处。今天发生了不少事，得好好想想。"
      },
      {
        "type": "wait_time",
        "duration": 500
      },
      {
        "type": "show_title",
        "text": "第二天",
        "duration": 1500
      },
      {
        "type": "fade_in",
        "duration": 1000
      }
    ]
  },
  {
    "id": "ghost_flashback",
    "commands": [
      {
        "type": "fade_black",
        "duration": 600
      },
      {
        "type": "show_movie_bar",
        "heightPercent": 0.12
      },
      {
        "type": "show_img",
        "id": "ghost_bride_memory",
        "image": "/assets/images/illustrations/ghost_bride_flashback.png"
      },
      {
        "type": "flash_white",
        "duration": 300
      },
      {
        "type": "show_dialogue",
        "speaker": "???",
        "text": "好一似食尽鸟投林……落了片白茫茫大地真干净……"
      },
      {
        "type": "camera_zoom",
        "scale": 1.5,
        "duration": 800
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "一个模糊的白色身影在月光下轻轻摇摆，唱腔婉转凄凉。你看不清她的脸，但那声音……像是在对你说话。"
      },
      {
        "type": "flash_white",
        "duration": 150
      },
      {
        "type": "wait_time",
        "duration": 300
      },
      {
        "type": "show_title",
        "text": "她是谁？",
        "duration": 2000
      },
      {
        "type": "camera_zoom",
        "scale": 1.0,
        "duration": 600
      },
      {
        "type": "hide_img",
        "id": "ghost_bride_memory"
      },
      {
        "type": "hide_movie_bar"
      },
      {
        "type": "fade_in",
        "duration": 800
      }
    ]
  },
  {
    "id": "peddler_arrives",
    "commands": [
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "街巷口传来一阵吆喝声。"
      },
      {
        "type": "camera_move",
        "x": 200,
        "y": 700,
        "duration": 1000
      },
      {
        "type": "show_dialogue",
        "speaker": "货郎",
        "text": "桃木片嘞——糯米嘞——艾草嘞——驱邪避凶保平安嘞——"
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "一个挑着担子的汉子出现在街口。看他那担子上的东西，倒都是些驱邪辟邪的玩意儿。"
      },
      {
        "type": "camera_move",
        "x": 600,
        "y": 500,
        "duration": 800
      },
      {
        "type": "set_flag",
        "key": "peddler_arrived",
        "value": true
      },
      {
        "type": "wait_click"
      },
      {
        "type": "show_dialogue",
        "speaker": "旁白",
        "text": "也许该去看看他卖的是什么。"
      }
    ]
  },
  {
    "id": "test_parallel",
    "commands": [
      {
        "type": "fade_black",
        "duration": 500
      },
      {
        "type": "show_title",
        "text": "演出系统测试",
        "duration": 2000
      },
      {
        "type": "fade_in",
