{
  "npc": {
    "x": {
      "kind": "number",
      "persistent": true,
      "picker": "plain",
      "apply": "position",
      "label": "x"
    },
    "y": {
      "kind": "number",
      "persistent": true,
      "picker": "plain",
      "apply": "position",
      "label": "y"
    },
    "enabled": {
      "kind": "boolean",
      "persistent": true,
      "picker": "plain",
      "apply": "visibility",
      "label": "enabled"
    },
    "animFile": {
      "kind": "string",
      "persistent": true,
      "picker": "animationManifest",
      "apply": "reloadAnimation",
      "label": "animFile"
    },
    "initialAnimState": {
      "kind": "string",
      "persistent": true,
      "picker": "animationState",
      "apply": "reloadAnimation",
      "label": "initialAnimState"
    },
    "animState": {
      "kind": "string",
      "persistent": true,
      "picker": "animationState",
      "apply": "playAnimation",
      "label": "animState"
    },
    "patrolDisabled": {
      "kind": "boolean",
      "persistent": true,
      "picker": "plain",
      "apply": "patrol",
      "label": "patrolDisabled"
    },
    "portraitSlug": {
      "kind": "string",
      "persistent": true,
      "picker": "portraitSlug",
      "apply": "none",
      "label": "portraitSlug（对话头像立绘集）"
    },
    "scale": {
      "kind": "number",
      "persistent": true,
      "picker": "plain",
      "apply": "transform",
      "label": "scale（实例等比缩放）"
    },
    "rotation": {
      "kind": "number",
      "persistent": true,
      "picker": "plain",
      "apply": "transform",
      "label": "rotation（实例旋转，度）"
    }
  },
  "hotspot": {
    "x": {
      "kind": "number",
      "persistent": true,
      "picker": "plain",
      "apply": "position",
      "label": "x"
    },
    "y": {
      "kind": "number",
      "persistent": true,
      "picker": "plain",
      "apply": "position",
      "label": "y"
    },
    "enabled": {
      "kind": "boolean",
      "persistent": true,
      "picker": "plain",
      "apply": "visibility",
      "label": "enabled"
    },
    "displayImage": {
      "kind": "object",
      "persistent": true,
      "picker": "hotspotDisplayImage",
      "apply": "reloadHotspotDisplayImage",
      "label": "displayImage"
    },
    "scale": {
      "kind": "number",
      "persistent": true,
      "picker": "plain",
      "apply": "transform",
      "label": "scale（实例等比缩放）"
    },
    "rotation": {
      "kind": "number",
      "persistent": true,
      "picker": "plain",
      "apply": "transform",
      "label": "rotation（实例旋转，度）"
    }
  }
}
