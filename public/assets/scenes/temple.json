{
  "id": "temple",
  "name": "破烂城隍庙",
  "width": 1400,
  "height": 1000,
  "backgroundScale": 1.3020833333,
  "backgrounds": [
    { "image": "/assets/images/backgrounds/temple_bg.png", "x": 0, "y": 0 }
