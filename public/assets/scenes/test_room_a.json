      "data": {
        "actions": [
          {
            "type": "playScriptedDialogue",
            "params": {
              "lines": [
                {
                  "speaker": "[tag:string:npc名字:卖糖画的商贩的名字]",
                  "text": "毛儿，来哟~来哟~抽龙哟！"
                }
              ]
            }
          },
          {
            "type": "chooseAction",
            "params": {
              "prompt": "转一把糖关刀？",
              "allowCancel": true,
              "options": [
                {
                  "text": "要（[tag:string:价格:抽糖画价格][tag:string:shop:unit]一次）",
                  "actions": [
                    {
                      "type": "startSugarWheelMinigame",
                      "params": {
                        "id": "sugar_zodiac"
                      }
                    }
                  ]
                },
                {
                  "text": "不要",
                  "actions": [
                    {
                      "type": "playScriptedDialogue",
                      "params": {
                        "lines": [
                          {
                            "speaker": "{{player}}",
                            "text": "包龙不？"
                          },
                          {
                            "speaker": "[tag:string:npc名字:卖糖画的商贩的名字]",
                            "text": "来嘛来嘛！包龙包龙。"
                          },
                          {
                            "speaker": "{{player}}",
                            "text": "抽抹火呀？嘻嘻嘻。"
                          },
                          {
                            "speaker": "[tag:string:npc名字:卖糖画的商贩的名字]",
                            "text": "爬爬爬！死叫花。"
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
