    {
      "id": "hs_纸扎日工",
      "type": "inspect",
      "label": "雾津纸扎铺 · 接桩糊纸人日工",
      "x": 700.0,
      "y": 580.0,
      "interactionRange": 60.0,
      "data": {
        "actions": [
          {
            "type": "playScriptedDialogue",
            "params": {
              "lines": [
                {
                  "speaker": "纸扎铺掌柜",
                  "text": "搭把手不嘛？铺子接了桩白事活路，糊几个随葬纸人，按件给钱。手脚麻利点，莫把忌讳犯了。"
                }
              ]
            }
          },
          {
            "type": "chooseAction",
            "params": {
              "prompt": "接这桩糊纸人的日工不？",
              "allowCancel": true,
              "options": [
                {
                  "text": "接（按件算钱）",
                  "actions": [
                    {
                      "type": "startPaperCraftMinigame",
                      "params": {
                        "id": "wujin_paper_servant_daywork"
                      }
                    }
                  ]
                },
                {
                  "text": "莫得空，先走",
                  "actions": []
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "hs_淹尸",
      "type": "inspect",
      "label": "苇席底下泡涨的尸",
      "x": 200.0,
      "y": 555.0,
      "interactionRange": 70.0,
      "conditions": [
        {
          "narrative": "flow_背尸_淹尸活",
          "state": "accepted"
        }
      ],
      "displayImage": {
        "image": "/resources/runtime/images/corpses/back_carry/waterlogged_corpse.png",
        "worldWidth": 140.0,
        "worldHeight": 70.0
      },
      "data": {
        "actions": [
          {
            "type": "sniff",
            "params": {}
          },
          {
            "type": "playScriptedDialogue",
            "params": {
              "lines": [
                {
                  "speaker": "",
                  "text": "掀开苇席一角：脸泡得发白发胀，衣裳还往外渗水。凑近一闻——臭是臭得淡，腥倒腥得很，一股子河底的凉气。"
                },
                {
                  "speaker": "{{player}}",
                  "text": "捞起没两天，还算新鲜。就是这水腥味……冲得很。"
                }
              ]
            }
          },
          {
            "type": "chooseAction",
            "params": {
              "prompt": "过肩搭手，背起来？",
              "allowCancel": true,
              "options": [
                {
                  "text": "背。八文钱的活，莫磨蹭。",
                  "actions": [
                    {
                      "type": "startPressureHold",
                      "params": {
                        "id": "carry_drowned_corpse"
                      }
                    }
                  ]
                },
                {
                  "text": "再缓缓，先看看再说。",
                  "actions": [
                    {
                      "type": "playScriptedDialogue",
                      "params": {
                        "lines": [
                          {
                            "speaker": "{{player}}",
                            "text": "日头毒了要出味……缓归缓，莫缓过头。"
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          }
        ]
      },
      "conditionHidesEntity": true
    }
