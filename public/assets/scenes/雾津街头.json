      ],
      "conditions": [
        {
          "plane": "背尸"
        },
        {
          "flag": "淹尸_烤过火",
          "op": "==",
          "value": false
        }
      ],
      "onEnter": [
        {
          "type": "playScriptedDialogue",
          "params": {
            "lines": [
              {
                "speaker": "",
                "text": "铺子廊檐下撂着一只瓦盆，纸灰未冷，底下还压着几星红炭——晓不得是哪家给亡人烧的。"
              }
            ]
          }
        },
        {
          "type": "chooseAction",
          "params": {
            "prompt": "借这盆纸火烘一烘？",
            "allowCancel": true,
            "options": [
              {
                "text": "烘。阳火驱阴湿，搭手的功夫而已。",
                "actions": [
                  {
                    "type": "waitMs",
                    "params": {
                      "ms": 1500
                    }
                  },
                  {
                    "type": "setFlag",
                    "params": {
                      "key": "淹尸_烤过火",
                      "value": true
                    }
                  },
                  {
                    "type": "healPlayer",
                    "params": {
                      "amount": 8
                    }
                  },
                  {
                    "type": "playScriptedDialogue",
                    "params": {
                      "lines": [
                        {
                          "speaker": "",
                          "text": "手心手背在炭火上翻了两遭，一股热气从掌心爬回胳膊——后颈那口凉，总算松了半分。"
                        },
                        {
                          "speaker": "{{player}}",
                          "text": "多谢哪个的火。走了。"
                        }
                      ]
                    }
                  }
                ]
              },
              {
                "text": "莫理。别家的火，别家的亡人。",
                "actions": [
                  {
                    "type": "playScriptedDialogue",
                    "params": {
                      "lines": [
                        {
                          "speaker": "{{player}}",
                          "text": "烧给亡人的火，我一个背死人子的凑啥子热闹。"
                        }
                      ]
                    }
                  }
                ]
              }
            ]
          }
        }
      ]
