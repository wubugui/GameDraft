{
  "name": "gamedraft",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:narrative-editor",
    "typecheck:narrative-editor": "tsc --noEmit -p tools/narrative_editor_web",
    "typecheck:anim-preview": "tsc --noEmit -p tools/anim_preview",
    "test:anim-preview": "node --test tools/anim_preview/*.test.mjs && vitest run tools/anim_preview/assemblyMath.test.ts",
    "build:narrative-editor": "npm run typecheck:narrative-editor && vite build --config tools/narrative_editor_web/vite.config.ts",
    "build:anim-preview-remote": "vite build --config tools/anim_preview/vite.remote.config.ts",
    "dev:narrative-editor": "vite --config tools/narrative_editor_web/vite.config.ts",
    "dev:anim-preview": "vite --config tools/anim_preview/vite.config.ts",
    "assemble:anim-preview-remote": "node tools/anim_preview/assemble_remote_deploy.mjs",
    "dev:parallax-editor": "vite --config tools/parallax_editor/vite.config.ts",
    "planner:gui": "node scripts/pytool.cjs production_workbench .",
    "preview": "vite preview",
    "filter-tool": "node scripts/pytool.cjs filter_tool",
    "test": "vitest run --exclude 'tools/anim_preview/*.test.mjs' && npm run test:anim-preview",
    "test:godot-visual-parity": "node godot_port/tools/visual_parity_runner.mjs --require-thresholds",
    "test:godot-scene-visuals": "node godot_port/tools/visual_scene_sweep.mjs --require-thresholds",
    "test:godot-fade-visuals": "node godot_port/tools/visual_fade_sweep.mjs --require-thresholds",
    "test:godot-dialogue-visuals": "node godot_port/tools/visual_dialogue_sweep.mjs --require-thresholds",
    "test:godot-minigame-visuals": "node godot_port/tools/visual_minigame_sweep.mjs --require-thresholds"
  },
  "type": "module",
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@xyflow/react": "^12.10.2",
    "elkjs": "^0.11.1",
    "gifenc": "^1.0.3",
    "howler": "^2.2.4",
    "pixi.js": "^8.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
