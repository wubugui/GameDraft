{
  "schemaVersion": 1,
  "sourceOfTruth": "Every non-test TypeScript module under src",
  "rules": [
    "One executable TypeScript module maps to one named Godot module unless the mapping declares an engine adapter.",
    "Class/module boundaries, constructor dependencies, fields, methods, method order, call order and failure semantics are preserved.",
    "Godot-only domain hooks, registration groups, service locators and compatibility staging are forbidden.",
    "Tests prove a translation; tests do not define replacement behavior.",
    "Declaration-only and barrel-only modules stay explicit in the ledger; they may omit a Godot target only because they own no runtime behavior."
  ],
  "engineAdapters": [
    {
      "sourcePrimitive": "JavaScript microtask queue and Promise continuation ordering",
      "target": "godot_port/scripts/runtime/microtask_queue.gd",
      "reason": "Godot has no browser microtask checkpoint, and a synchronous GDScript await does not yield like await Promise.resolve(...); the adapter preserves queueMicrotask, Promise-tail and continuation order without moving domain decisions out of their source modules."
    },
    {
      "sourcePrimitive": "browser fetch/URL resolution",
      "target": "godot_port/scripts/runtime/resource_locator.gd",
      "reason": "Godot loads the same exported resource tree through res:// and filesystem paths."
    },
    {
      "sourcePrimitive": "Promise-based local asset reads",
      "target": "godot_port/scripts/runtime/asset_manager.gd",
      "reason": "Godot ResourceLoader/filesystem access is synchronous, so the source inflight Promise interval collapses; null/false plus get_last_error form the explicit adapter for rejected asset Promises while cache sequencing stays source-owned."
    },
    {
      "sourcePrimitive": "ArchiveManager requestIdleCallback with setTimeout fallback and pooled asynchronous texture preload",
      "target": "godot_port/scripts/systems/archive_manager.gd SceneTreeTimer and synchronous bounded round-robin preload boundary",
      "reason": "Godot has no browser idle callback and local ResourceLoader reads are synchronous; a cancellable 1.5-second SceneTreeTimer preserves the source fallback lifetime while the three-worker Promise pool collapses to the same bounded texture start order."
    },
    {
      "sourcePrimitive": "browser DOM keyboard/pointer/focus listeners",
      "target": "godot_port/scripts/runtime/input_manager.gd",
      "reason": "Godot delivers the same event lifecycle through Node _input and application focus notifications; DOM code names are normalized at this boundary."
    },
    {
      "sourcePrimitive": "DebugTools browser DOM listeners and HTMLElement debug controls",
      "target": "godot_port/scripts/core/debug_tools.gd and godot_port/scripts/ui/debug_panel_ui.gd",
      "reason": "Godot routes the source-owned debug input lifecycle through Node _input and translates the same section action/extra-control shape to Control nodes; DebugTools retains all debug state, decisions and callbacks."
    },
    {
      "sourcePrimitive": "browser DOM fixed-position development error overlay",
      "target": "godot_port/scripts/core/dev_error_overlay.gd",
      "reason": "Godot has no DOM; a top-layer CanvasLayer preserves the development-only console reporting, visible overlay, duplicate folding and clear lifecycle without moving error classification out of source-owning modules."
    },
	{
	  "sourcePrimitive": "Pixi filter arrays, GPU filter construction, and CanvasItem material binding",
	  "target": "godot_port/scripts/rendering/scene_depth_filter_adapter.gd and godot_port/scripts/rendering/scene_entity_filter_binding.gd",
	  "reason": "Godot exposes one CanvasItem material instead of Pixi filter arrays; these adapters only translate GPU uniforms and attachment metadata while SceneDepthSystem retains the source filter collection, creation, update and removal ownership."
	},
	{
	  "sourcePrimitive": "DepthDebugVisualizer Pixi background-layer filter attachment",
	  "target": "godot_port/scripts/debug/depth_debug_visualizer.gd and the CanvasGroup background layer in godot_port/scripts/rendering/renderer.gd",
	  "reason": "Godot composites a group through one CanvasGroup material; the adapter preserves the source visualizer's mode, scene-data, attach/detach and lifetime ownership without relocating its debug decisions."
	},
    {
      "sourcePrimitive": "browser localStorage string key/value persistence",
      "target": "godot_port/scripts/runtime/local_storage.gd",
      "reason": "Godot has no browser localStorage; the adapter preserves getItem/setItem/removeItem null and failure semantics over atomic user-storage files while SaveManager retains the source fields and raw-string API."
    },
    {
      "sourcePrimitive": "JavaScript Promise tail chaining",
      "target": "godot_port/scripts/runtime/async_tail.gd",
      "reason": "GDScript coroutines are not first-class Promises; the adapter preserves then(run, run) serialization while domain managers retain one tail field."
    },
    {
      "sourcePrimitive": "JavaScript Promise completion latch",
      "target": "godot_port/scripts/runtime/async_latch.gd",
      "reason": "GDScript has no first-class Promise constructor; resolve/reject/wait latches preserve Game-owned EventBus completion and NarrativeStateManager queued-item/drain/nested-drain promise ownership without moving domain decisions into adapters."
    },
    {
      "sourcePrimitive": "JavaScript exception and rejected-Promise failure channel",
      "target": "Godot translated runtime methods returning false or null",
      "reason": "GDScript has no catchable exception channel; false for boolean/void guards and null for value-returning guards mechanically represent a thrown domain guard or rejected Promise without moving the validation decision into another owner."
    },
    {
      "sourcePrimitive": "JavaScript String/Number coercion, truthy fallback, and caught Error result construction",
      "target": "godot_port/scripts/runtime/javascript_runtime_adapter.gd",
      "reason": "GDScript lacks JavaScript undefined/coercion and catchable exceptions; the adapter contains only language-level conversion and error-result mechanics so devRuntimeCommands remains a fieldless file module with the same function surface and dispatch ownership."
    },
    {
      "sourcePrimitive": "Vite import.meta.env accessed through NarrativeStateManager's local import.meta alias",
      "target": "godot_port/scripts/systems/narrative_state_manager.gd inline platform boundary",
      "reason": "Vite does not inject env fields through the source's indirect meta alias, so its effective DEV/MODE/custom values are absent. The inline target translation preserves that observed source behavior instead of incorrectly substituting Godot's engine debug-build bit."
    }
  ],
